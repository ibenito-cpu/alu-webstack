global
    log /dev/log local0
    log /dev/log local1 notice
    chroot /var/lib/haproxy
    stats socket /run/haproxy/admin.sock mode 660 level admin
    stats timeout 30s
    user haproxy
    group haproxy
    daemon
    maxconn 2048
    tune.ssl.default-dh-param 2048

defaults
    log     global
    mode    http
    option  httplog
    option  dontlognull
    timeout connect 5000
    timeout client  50000
    timeout server  50000

frontend www-https
    # Bind to port 443 and specify the path to the combined PEM file
    bind *:443 ssl crt /etc/haproxy/certs/www.ibenito.tech.pem
    
    # Pass a header to the backend so it knows the original request was HTTPS
    http-request set-header X-Forwarded-Proto https
    
    default_backend web-backend

backend web-backend
    balance roundrobin
    # Pointing to your specific web server IPs on port 80
    server web-01 35.173.178.76:80 check
    server web-02 54.174.21.203:80 check
