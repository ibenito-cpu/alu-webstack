#!/usr/bin/env bash
# Displays information about subdomains
# shellcheck disable=SC2086

get_info() {
    dig $2.$1 +noall +answer | awk -v sub=$2 '{print "The subdomain " sub " is a " $4 " record and points to " $5}'
}

if [ $# -eq 1 ]; then
    get_info $1 www
    get_info $1 lb-01
    get_info $1 web-01
    get_info $1 web-02
elif [ $# -eq 2 ]; then
    get_info $1 $2
fi
